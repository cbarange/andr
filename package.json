{
  "name": "darkroom3d-poc",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Proof of Concept — A Dark Room 3D (web natif, Babylon.js + WebGPU + Havok + Trystero)",
  "scripts": {
    "postinstall": "node scripts/copy-havok-wasm.mjs",
    "predev": "node scripts/copy-havok-wasm.mjs",
    "prebuild": "node scripts/copy-havok-wasm.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@babylonjs/core": "^9.11.0",
    "@babylonjs/havok": "^1.3.12",
    "trystero": "^0.25.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
